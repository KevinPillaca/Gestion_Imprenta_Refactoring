{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "./src",        // Mantenemos tu código limpio en src
    "outDir": "./dist",
    "esModuleInterop": true,
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],     // SOLO incluimos lo que vas a programar tú
  "exclude": [
    "node_modules", 
    "dist", 
    "prisma", 
    "prisma.config.ts"         // <--- AQUÍ está el secreto: lo excluimos
  ]
}